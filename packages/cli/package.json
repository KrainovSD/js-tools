{
  "name": "@krainovsd/cli",
  "version": "0.3.9",
  "description": "Krainov cli",
  "type": "module",
  "author": "KrainovSD <denislosev48@gmail.com>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KrainovSD/js-tools.git",
    "directory": "packages/cli"
  },
  "bin": {
    "ksd": "./lib/wrapper.js"
  },
  "files": [
    "lib/wrapper.js",
    "lib/postinstall.js",
    "bin"
  ],
  "sideEffects": false,
  "keywords": [
    "cli",
    "js"
  ],
  "scripts": {
    "build": "npm run build:ts && node lib/build.js",
    "build:ts": "tsc -p tsconfig.build.json",
    "publish-package": "npm run build  && npm publish",
    "lint": "eslint . -c ./eslint.config.js --color --max-warnings 0",
    "format": "prettier --write 'src/**/*.{js,ts,tsx,scss,css,json}'",
    "format-check": "prettier --check ./src",
    "lint-check": "eslint --debug eslint.config.js",
    "type-debug": "tsc --showConfig > typescript-config.json",
    "postinstall": "node lib/scripts/postinstall.js || true",
    "test-translate": "go run main.go translates gen react ru.json ./"
  },
  "devDependencies": {
    "@krainovsd/presets": "0.4.0",
    "typescript": "5.8.3",
    "@types/node": "22.13.8",
    "eslint": "9.29.0",
    "prettier": "3.6.1"
  }
}
